{
  "name": "story-harness-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local web play surface for Story Harness — drives the user's own Claude Code.",
  "scripts": {
    "dev": "concurrently -k -n bridge,web -c blue,green \"npm:dev:bridge\" \"npm:dev:web\"",
    "dev:bridge": "tsx watch server/bridge.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "npm run build && tsx server/bridge.ts --serve-static",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
